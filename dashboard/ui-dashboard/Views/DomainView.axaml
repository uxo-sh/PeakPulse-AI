<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:ui_dashboard.Controls"
    xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    x:Class="ui_dashboard.Views.DomainView"
    Background="{DynamicResource AppBg}">
    <ScrollViewer>
        <StackPanel Margin="30">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,20">
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Name="DomainIcon"
                            Width="26" Height="26"
                            Foreground="{DynamicResource AccentBlue}" />
                        <TextBlock Name="TitleText"
                            Foreground="{DynamicResource TextPrimary}"
                            FontSize="24" FontWeight="Bold" />
                    </StackPanel>
                    <TextBlock Name="SubtitleText"
                        Foreground="{DynamicResource TextMuted}"
                        FontSize="12" Margin="0,6,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                    Background="{DynamicResource CardBg}"
                    CornerRadius="8" Padding="14,10"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <material:MaterialIcon Kind="Calendar"
                            Width="13" Height="13"
                            Foreground="{DynamicResource AccentBlue}"
                            VerticalAlignment="Center" />
                        <TextBlock Name="DateText"
                            Foreground="{DynamicResource AccentBlue}"
                            FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Barre de recherche  -->
            <Grid ColumnDefinitions="400,*,Auto" Margin="0,0,0,24">

                <!-- Barre de recherche -->
                <Border Grid.Column="0"
                    Background="{DynamicResource CardBg}"
                    CornerRadius="8" Padding="12,0"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    Margin="0,0,12,0">
                    <Grid ColumnDefinitions="Auto,*">
                        <material:MaterialIcon Grid.Column="0"
                            Kind="Magnify"
                            Width="16" Height="16"
                            Foreground="{DynamicResource TextMuted}"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                            Name="SearchBox"
                            Watermark="Rechercher un genre, une tendance..."
                            Background="Transparent"
                            BorderThickness="0"
                            BorderBrush="Transparent"
                            Foreground="{DynamicResource TextPrimary}"
                            FontSize="13"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Stretch"
                            CaretBrush="{DynamicResource AccentBlue}"
                            KeyDown="OnSearchKeyDown">
                            <TextBox.Styles>
                                <Style Selector="TextBox:focus /template/ Border">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BoxShadow" Value="none" />
                                </Style>
                                <Style Selector="TextBox:pointerover /template/ Border">
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                </Style>
                            </TextBox.Styles>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Bouton Analyser -->
                <Button Grid.Column="2"
                    Name="BtnAnalyze"
                    Click="OnAnalyzeClick"
                    Background="{DynamicResource AccentBlue}"
                    Padding="14,10"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="ChartLine"
                            Width="16" Height="16"
                            Foreground="White" />
                        <TextBlock Name="BtnAnalyzeText" Text="Analyser"
                            Foreground="White"
                            FontSize="12" FontWeight="Bold" />
                    </StackPanel>
                </Button>


            </Grid>

            <!-- Notifications -->
            <StackPanel Name="NotificationPanel" />

            <!-- KPI Cards -->
            <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,24">
                <c:KpiCard Grid.Column="0" Classes="fadeIn" Name="KpiRecall"
                    Margin="0,0,8,0" Label="RECALL"
                    Trend="↑" SubLabel="sensibilité"
                    ColorHex="#4fc3f7" IconKind="Target" />
                <c:KpiCard Grid.Column="1" Classes="fadeIn1" Name="KpiF1"
                    Margin="4,0" Label="F1 SCORE"
                    Trend="↑" SubLabel="équilibre"
                    ColorHex="#7c4dff" IconKind="ScaleBalance" />
                <c:KpiCard Grid.Column="2" Classes="fadeIn2" Name="KpiAuc"
                    Margin="4,0" Label="ROC AUC"
                    Trend="↑" SubLabel="séparabilité"
                    ColorHex="#ff6b6b" IconKind="ChartLineVariant" />
                <c:KpiCard Grid.Column="3" Classes="fadeIn3" Name="KpiPrecision"
                    Margin="8,0,0,0" Label="PRÉCISION IA"
                    Trend="sur 10" SubLabel="RandomForest"
                    ColorHex="#4caf50" IconKind="Brain" />
            </Grid>

            <!-- Line chart -->
            <c:LineChart Name="MainLineChart"
                Classes="fadeIn2"
                Margin="0,0,0,24"
                Title="Évolution du score — 6 derniers mois"
                Badge="Live"
                ColorHex="#4fc3f7"
                DataPoints="60,75,90,85,100,115" />

            <!-- Circle bars
            <Grid ColumnDefinitions="*,*,*" Margin="0,0,0,24">
                <c:CircleBar Grid.Column="0" Classes="fadeIn1" Name="CircleScore"
                    Margin="0,0,8,0"
                    Title="SCORE GLOBAL"
                    Value="78" MaxValue="100"
                    ColorHex="#4fc3f7"
                    Label="sur 100 points" />
                <c:CircleBar Grid.Column="1" Classes="fadeIn2" Name="CirclePrecision"
                    Margin="4,0"
                    Title="PRÉCISION IA"
                    Value="92" MaxValue="100"
                    ColorHex="#4caf50"
                    Label="RandomForest" />
                <c:CircleBar Grid.Column="2" Classes="fadeIn3" Name="CircleOpportunity"
                    Margin="8,0,0,0"
                    Title="OPPORTUNITÉS"
                    Value="70" MaxValue="100"
                    ColorHex="#ff6b6b"
                    Label="fenêtre optimale" />
            </Grid> -->
            <!-- Bar chart + Top genres -->
            <Grid ColumnDefinitions="*,300" Margin="0,0,0,24">
                <c:BarChart Grid.Column="0" Classes="fadeIn3" Name="MainChart"
                    Margin="0,0,12,0" />
                <Border Grid.Column="1"
                    Background="{DynamicResource CardBg}"
                    CornerRadius="12" Padding="24"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8"
                            Margin="0,0,0,20">
                            <material:MaterialIcon Kind="TrophyVariant"
                                Width="16" Height="16"
                                Foreground="{DynamicResource BadgeYellow}" />
                            <TextBlock Text="Top Genres"
                                Foreground="{DynamicResource TextPrimary}"
                                FontSize="14" FontWeight="Bold" />
                        </StackPanel>
                        <StackPanel Name="TopGenresPanel" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Top 10 : Genres émergents -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="24" Margin="0,0,0,24" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Top 10 : Genres émergents" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>
                    <StackPanel Name="EmergentGenresPanel" />
                </StackPanel>
            </Border>

            <!-- Top 5 : Par probabilité moyenne -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="24" Margin="0,0,0,24" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Top 5 : Par probabilité moyenne" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>
                    <StackPanel Name="MeanProbaGenresPanel" />
                </StackPanel>
            </Border>

            <!-- Top 5 : Par % prédit tendance -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="24" Margin="0,0,0,24" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Top 5 : Par % prédit tendance" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" Margin="0,0,0,16"/>
                    <StackPanel Name="TrendPercentGenresPanel" />
                </StackPanel>
            </Border>

            <!-- Ceux qui vont exploser -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="24" Margin="0,0,0,24" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                <StackPanel>
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
                        <TextBlock Grid.Column="0" Text="Ceux qui vont exploser" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Bold" />
                        <Border Grid.Column="1" Background="#1a3a1a" CornerRadius="6" Padding="10,4">
                            <TextBlock Name="OpportunityBadge" Foreground="#4caf50" FontSize="11" />
                        </Border>
                    </Grid>
                    <!-- En-têtes pour les détails (Games / Movies) -->
                    <Grid ColumnDefinitions="*,90,200,120" Margin="0,0,0,8">
                        <TextBlock Grid.Column="0" Text="Titre" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                        <TextBlock Grid.Column="1" Name="Header1" Text="Score" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                        <TextBlock Grid.Column="2" Name="Header2" Text="Proba" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                        <TextBlock Grid.Column="3" Name="Header3" Text="Budget" Foreground="{DynamicResource TextMuted}" FontSize="11" />
                    </Grid>
                    <StackPanel Name="ExplodingItemsPanel" />
                </StackPanel>
            </Border>

            <!-- Recommandation IA -->
            <Border Background="{DynamicResource CardBg}"
                CornerRadius="12" Padding="24"
                BorderBrush="{DynamicResource AccentBlue}"
                BorderThickness="1">
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0"
                        Background="{DynamicResource NavActive}"
                        CornerRadius="8" Padding="10"
                        Margin="0,0,16,0" Width="44" Height="44">
                        <material:MaterialIcon Kind="Robot"
                            Width="24" Height="24"
                            Foreground="{DynamicResource BadgeYellow}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <StackPanel Orientation="Horizontal" Spacing="8"
                            Margin="0,0,0,8">
                            <material:MaterialIcon Kind="TrendingUp"
                                Width="14" Height="14"
                                Foreground="{DynamicResource AccentBlue}" />
                            <TextBlock Name="IaTitle"
                                Foreground="{DynamicResource AccentBlue}"
                                FontSize="13" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Name="IaText"
                            Foreground="{DynamicResource TextSecondary}"
                            FontSize="12" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>