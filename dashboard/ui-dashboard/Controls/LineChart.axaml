<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="ui_dashboard.Controls.LineChart">

  <Border Background="{DynamicResource CardBg}"
      CornerRadius="12" Padding="24"
      BorderBrush="{DynamicResource BorderColor}"
      BorderThickness="1">
    <StackPanel>
      <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,16">
        <TextBlock Name="TitleText"
          Grid.Column="0"
          Foreground="{DynamicResource TextPrimary}"
          FontSize="13" FontWeight="Bold" />
        <Border Grid.Column="1"
          Background="#0e2a1a"
          CornerRadius="20" Padding="10,3"
          BorderBrush="#1a5a2a" BorderThickness="1">
          <TextBlock Name="BadgeText"
            Foreground="#00e676"
            FontSize="10" FontWeight="Bold" />
        </Border>
      </Grid>

      <Canvas Name="LineCanvas" Height="160" />

      <Grid Name="LabelsGrid" Margin="0,8,0,0" />
    </StackPanel>
  </Border>
</UserControl>
